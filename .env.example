# ---------------------------------------------------------------------------
# Copy this file to ".env" and adjust values for your environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=UTC

# Database
# Local dev uses SQLite automatically if DATABASE_URL is unset.
# PostgreSQL example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Email (defaults to console backend in dev — prints emails to the terminal)
# For real SMTP, set EMAIL_BACKEND and the host details below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Portfolio <no-reply@example.com>
CONTACT_NOTIFY_EMAIL=owner@example.com

# Production-only security toggles (ignored when DEBUG=True)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000
